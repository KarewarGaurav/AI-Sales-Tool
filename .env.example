# Copy to .env for local dev, or set in your hosting provider for production builds.
# Never commit .env (see .gitignore).

# --- Development (Vite proxy — avoids CORS) ---
# VITE_API_URL=/api
# VITE_PROXY_TARGET=https://your-n8n-instance.example.com

# --- Production (direct n8n or your API gateway) ---
# Use full origin + webhook path, OR same-origin /api with reverse proxy.
VITE_API_URL=https://your-n8n-instance.example.com
VITE_API_WEBHOOK_PROD=/webhook/your-webhook-id

# Optional: dev-only proxy target (vite.config.js)
# VITE_PROXY_TARGET=https://your-n8n-instance.example.com
